    <siteMapNode title="Blog" description="Blog" url="~/blog/">
      <siteMapNode title="Culoarea Ideala Vopsea Lavabila" description="Romtehnochim este producator al unei game vaste de vopsele lavabile. Toate pot fi colorate la cerere, sau pot fi nuantate cu paste de colorare." url="~/blog/culoarea-ideala-vopsea-lavabila" />
      <siteMapNode title="Emailuri Alchidice Vopsele De Uz General" description="Emailurile alchidice sunt produse de uz general pentru protejarea suprafetelor din lemn metal sau zidarie cu putere mare de acoperire si luciu intens" url="~/blog/emailuri-alchidice-vopsele-de-uz-general" />
      <siteMapNode title="Emex Consiliere Specializata Vopsire" description="Pentru reusita unor vopsiri sau aplicari de pardoseala la un nivel calitativ superior este necesar un instructaj privind modalitatile de utilizare." url="~/blog/emex-consiliere-specializata-vopsire" />
      <siteMapNode title="Emex Trs 700 Vopsea Termorezistenta" description="Vopseaua termorezistenta Emex TRS – 700 se remarca prin capacitatea mare de protectie fata de temperaturi ridicate, in special la cuptoare industriale" url="~/blog/emex-trs-700-vopsea-termorezistenta" />
      <siteMapNode title="Emex Vopsea Profesionala Pentru Marcaj Rutier" description="Vopsea de marcaj rutier Emex Route este un produs cu proprietati superioare destinat marcajelor stradale atat pentru traficul auto cat si cel pietonal" url="~/blog/emex-vopsea-profesionala-pentru-marcaj-rutier" />
      <siteMapNode title="Finisare Cu Lac Epoxidic Emex Epoxy Coat" description="Produs bicomponent profesional cu proprietati superioare de protectie, rezistent la variatii de temperatura, socuri mecanice, coroziune, uzura, frecare" url="~/blog/finisare-cu-lac-epoxidic-emex-epoxy-coat" />
      <siteMapNode title="Hammerschlag Vopsea Lovitura De Ciocan" description="Vopseaua hammerschag sau lovitura de ciocan este o vopsea decorativa pe baza de rasini sintetice pasta de bronz aluminiu si pigmenti organici RAL" url="~/blog/hammerschlag-vopsea-lovitura-de-ciocan" />
      <siteMapNode title="Lac De Piatra Si Beton Amprentat" description="Lac pentru protejare suprafete din beton ciment mozaic sau alte materiale minerale cu capacitate mare de protectie si rezistenta la intemperii si UV" url="~/blog/lac-de-piatra-si-beton-amprentat" />
      <siteMapNode title="Lac De Protectie Beton Emex" description="Lacul de protectie pentru beton are o mare eficienta la protejarea suprafetelor din beton ciment sau suprafete minerale impotriva factorilor de mediu." url="~/blog/lac-de-protectie-beton-emex" />
      <siteMapNode title="Lac Epoxidic Pentru Pardoseli Durabile" description="Lac epoxidic profesional pentru protectia suporturilor din beton, sigilarea si fixarea suporturilor sau lacuirea pardoselilor sau vopsirilor epoxidice" url="~/blog/lac-epoxidic-pentru-pardoseli-durabile" />
      <siteMapNode title="Lacuri Lemn Mobila" description="Romtehnochim produce lacuri de mobila parchet sau lemn sub marca Emex, cu caracteristici superioare de pelicula si rezistenta mare la factori agresori" url="~/blog/lacuri-lemn-mobila" />
      <siteMapNode title="Marcaj Rutier Siguranta In Trafic" description="Vopseaua pentru marcaj rutier trebuie sa prezinte acele caracteristici care sa asigure o fiabilitate mare si rezistenta la trafic intens si solicitari" url="~/blog/marcaj-rutier-siguranta-in-trafic" />
      <siteMapNode title="Pardoseala Epoxidica Decorativa Emex" description="Pardoselile epoxidice pentru suprafete exterioare sunt realizarete sin rasini epoxidice special destinate acestui tip de aplicare lacuite la final" url="~/blog/pardoseala-epoxidica-decorativa-emex" />
      <siteMapNode title="Pardoseala Epoxidica Emex Quartz" description="Produs de generatie noua &amp;#11088; Pardoseala Epoxidica cu Cuartz este ideala pentru protectia pardoselilor de beton &amp;#9989; Pret Atractiv si Performante Ridicate !" url="~/blog/pardoseala-epoxidica-emex-quartz" />
      <siteMapNode title="Pardoseala Epoxidica Garantia Calitatii Emex" description="Sistemele epoxidice pentru pardoseala exceleaza prin rezistenta lo la facotri chimici si mecanici dar mai ales prin rezistenta mare la trafic intens" url="~/blog/pardoseala-epoxidica-garantia-calitatii-emex" />
      <siteMapNode title="Pardoseli Epoxidice Avizate Sanitar" description="Pardoselile sau vopselele epoxidice sunt produse care pot respecta cu usurinta cerintele speciale de igiena cerute in zonele medicale sau alimentare" url="~/blog/pardoseli-epoxidice-avizate-sanitar" />
      <siteMapNode title="Promotie Tencuiala Decorativa Emex" description="Tencuiala decorativa acrilica este un produs standard cu proprietati superioare si o durata de viata de minim 10 ani; acum la un pret promotional" url="~/blog/promotie-tencuiala-decorativa-emex" />
      <siteMapNode title="Protectia Suporturilor Metalice Cu Vopsea Clorcauciuc" description="O protectie foarte eficienta a suporturilor metalice poate fi realizata prin folosirea unui sistem de grund clorcauciuc cu vopsea clorcauciuc Emex" url="~/blog/protectia-suporturilor-metalice-cu-vopsea-clorcauciuc" />
      <siteMapNode title="Sistem De Pardoseala Covor Epoxidic Emex" description="Covorul epoxidic de cuartz este probabil cel mai rezistent sistem de pardoseala. Se remarca si prin duritate, aspect decorativ si durabilitate in timp" url="~/blog/sistem-de-pardoseala-covor-epoxidic-emex" />
      <siteMapNode title="Sisteme Vopsire Ecologice Emex" description="Sistemele moderne de vopsire au in vedere in mod prioritar lipsa toxicitatii fata de om sau mediu, fiind realizate pe baza de rasini solubile in apa." url="~/blog/sisteme-vopsire-ecologice-emex" />

# ----------------------------------------------------------------------
# Apache server configuration for a Laravel project
# Placed in the ROOT directory of the Laravel project.
# ----------------------------------------------------------------------

# Disable directory browsing globally
Options -Indexes

# Enable symbolic links if you use them (e.g., for storage)
# Options +FollowSymLinks
# If your host requires it, you might need Options +SymLinksIfOwnerMatch

# PHP settings (Consider moving these to php.ini or FPM pool config for better practice)
# If using mod_php and not PHP-FPM. For PHP 7/8, use php_module not php5_module.
# <IfModule php_module>
#   php_value session.cookie_httponly true
#   php_value session.cookie_secure true # Important: Only if site is ALWAYS HTTPS
# </IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    ## ----------------------------------------------------------------------
    ## SECTION 1: Canonicalization (HTTPS, www/non-www) & HSTS
    ## ----------------------------------------------------------------------

    # Force HTTPS and non-WWW (emex.ro)
    # Adjust www preference as needed.
    RewriteCond %{HTTPS} off [OR]
    RewriteCond %{HTTP_HOST} ^www\. [NC]
    RewriteCond %{HTTP_HOST} ^(?:www\.)?(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301,NE]

    # HSTS (Strict Transport Security) - DO NOT enable until HTTPS is fully working
    # This tells browsers to only access your site via HTTPS for the max-age duration.
    <IfModule mod_headers.c>
        Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" env=HTTPS
    </IfModule>

    ## ----------------------------------------------------------------------
    ## SECTION 2: Security - Block direct access to sensitive files/folders
    ## ----------------------------------------------------------------------

    # Block access to "hidden" directories and files (e.g., .git, .env)
    # Allow .well-known for SSL certificates (Let's Encrypt)
    RewriteRule "(^|/)\.(?!well-known(/|$))" - [F,L]

    ## ----------------------------------------------------------------------
    ## SECTION 3: Prevent direct access to /public/ or /public/index.php in URL
    ## THIS IS KEY TO SOLVING YOUR SPECIFIC PROBLEM
    ## ----------------------------------------------------------------------

    # Redirect direct requests for /public/anything to /anything (clean URL)
    #RewriteCond %{THE_REQUEST} \s/public/([^\s?]*) [NC]
    #RewriteRule ^ /%1 [L,R=301,NE]

    # Redirect direct requests for /public/index.php/anything to /anything (clean URL)
    RewriteCond %{THE_REQUEST} \s/public/index\.php/?([^\s?]*) [NC]
    RewriteRule ^ /%1 [L,R=301,NE]

    ## ----------------------------------------------------------------------
    ## SECTION 4: Custom Redirects (Place before Laravel's main router)
    ## ----------------------------------------------------------------------

    # Your specific PDF redirect (example)
    # Ensure the target path is correct relative to your web server's DocumentRoot
    # If DocumentRoot is Laravel project root, then /public/storage/... is correct for symlinked storage
    RewriteRule ^Doc/Lavabila-cuartz-profesioanala-Emex-QT\.pdf$ /public/storage/media/technical-files/lavabila-cuartz-profesionala-emex-qt.pdf [L,R=301,NC,QSD]
    # NC: NoCase - makes the match case-insensitive
    # QSD: Query String Discard - removes any query string from the original request

    # Commented out general doc redirects (uncomment and adapt if needed)
    # RewriteRule ^doc/(.*)$ /public/storage/media/technical-files/$1 [L,R=301,NC,QSD]
    # RewriteRule ^Doc/(.*)$ /public/storage/media/technical-files/$1 [L,R=301,NC,QSD] # Covered by NC above

#RewriteRule ^$ public/index.php [L]

    ## ----------------------------------------------------------------------
    ## SECTION 5: Laravel Front Controller (Routing all non-asset requests to public/index.php)
    ## ----------------------------------------------------------------------

    # Handle Authorization Header (needed for API token authentication, etc.)
    #RewriteCond %{HTTP:Authorization} .
    #RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # If the request is for an existing file or directory in the 'public' folder,
    # serve it directly. This allows assets (CSS, JS, images) to be served.
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -d
    RewriteRule ^(.+)$ public/$1 [L]

    # Otherwise, send the request to Laravel's front controller (public/index.php)
    # Ensure this condition is met ONLY if it's not an actual file/dir already served
    # The conditions above should handle assets, so this mostly catches dynamic routes.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/index.php [L,QSA]
    # QSA: Query String Append - appends any query string from the original request

</IfModule>

# Block access to specific sensitive file types and names (outside mod_rewrite)
# This should be a global setting or outside the IfModule block.
<FilesMatch "(\.(bak|bat|config|dist|fla|inc|ini|log|md|psd|sh|sql|swp)|~|composer\.json|composer\.lock|\.env)$">
    Order allow,deny
    Deny from all
    Satisfy All
</FilesMatch>
